# .env.example — API key template
#
# Copy this file to .env and populate with your real keys.
# The .env file is gitignored — your keys never enter git history.
#
# cp .env.example .env
#
# Get free API keys from:
#   yfinance    — no key required, works out of the box
#   Alpha Vantage — free key at https://www.alphavantage.co/support/#api-key

# Alpha Vantage free tier — used as fallback if yfinance fails
# Free tier allows 25 requests per day, 5 per minute
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
